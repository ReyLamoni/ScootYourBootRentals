# ═══════════════════════════════════════════════════════
#  Scoot Your Boot Rentals — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — keep it secret!
# ═══════════════════════════════════════════════════════

# ── Admin Password ────────────────────────────────────
# Paste the bcrypt hash generated by: node scripts/hash-password.js
ADMIN_PASSWORD_HASH=

# ── Resend Email Notifications ────────────────────────
# 1. Sign up free at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste it here:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address YOU want notifications sent TO.
# This is where you'll receive alerts when someone submits a rental request.
# Can be any email address — Gmail, iCloud, etc.
NOTIFY_EMAIL=your-email@example.com

# The "from" address shown on notification emails.
# OPTION A (easiest — no setup needed, works immediately):
#   Use Resend's default: onboarding@resend.dev
#   Just leave FROM_EMAIL blank and it will use that automatically.
#
# OPTION B (looks more professional):
#   Use your own domain, e.g. notify@scootyourboot.com
#   Requires verifying your domain in the Resend dashboard first.
#   See: https://resend.com/docs/dashboard/domains/introduction
FROM_EMAIL=

# ── Server ────────────────────────────────────────────
PORT=3000
